# Tomorrowland production Compose environment template.
# Copy to `.env`, replace every `change-me-*` placeholder before storing real data,
# and keep this file free of real passwords, tokens, and secrets.

# Required: runtime profile for the API containers; production Compose should use `prod`.
APP_ENV=prod
# Optional build metadata exposed as Prometheus labels; set during image/build promotion when available.
APP_VERSION=0.1.0
BUILD_COMMIT=unknown
# Optional: log level for the API and service loggers; one of `critical`, `error`, `warning`, `info`, `debug`.
LOG_LEVEL=info

# Core services
# Required: PostgreSQL database name created by the postgres container.
POSTGRES_DB=app
# Required: PostgreSQL user created by the postgres container.
POSTGRES_USER=postgres
# Required secret: PostgreSQL password; replace before first production use.
POSTGRES_PASSWORD=change-me-postgres-password
# Required: SQLAlchemy database URL; keep the user, password, host, port, and DB in sync with POSTGRES_*.
POSTGRES_URL=postgresql+psycopg://postgres:change-me-postgres-password@postgres:5432/app
# Required: Kafka/Redpanda broker URL used by event publishers.
KAFKA_BROKER=kafka:9092
# Required: Elasticsearch HTTP URL used for full-text indexing and search.
ELASTIC_URL=http://elasticsearch:9200
# Required: Qdrant HTTP URL used for vector storage and semantic search.
QDRANT_URL=http://qdrant:6333
# Meilisearch: base URL and API keys (see docs/implementation/meilisearch-security.md).
# MEILISEARCH_MASTER_KEY must be a long random secret; never expose it to the frontend.
# MEILISEARCH_SEARCH_KEY is a scoped search-only key generated from the master key at startup.
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change-me-meilisearch-master-key
MEILISEARCH_SEARCH_KEY=
# Feature flags: enable Meilisearch for queries and/or dual-write shadow indexing.
FEATURE_MEILISEARCH_SEARCH=false
FEATURE_MEILISEARCH_SHADOW_INDEX=false
# Optional: enable Meilisearch native hybrid search (BM25 + vector via Ollama embedder).
# When true, Meilisearch calls ollama-embed directly during indexing.
# embed-worker, vector-worker, and qdrant are no longer needed and can be
# omitted by not starting the legacy-vector Docker Compose profile.
FEATURE_MEILISEARCH_HYBRID=false
# Meilisearch embedder name (must match the key in the index embedders settings).
MEILI_EMBEDDER_NAME=default
# Semantic weight in hybrid queries (0.0 = BM25 only, 1.0 = vector only).
MEILI_SEMANTIC_RATIO=0.5
# RabbitMQ: durable transport for document-processing jobs.
# RABBITMQ_ENABLED=true enables RabbitMQ stage-based job bus (recommended).
RABBITMQ_URL=amqp://tomorrowland:changeme@rabbitmq:5672/
RABBITMQ_USER=tomorrowland
RABBITMQ_PASS=changeme
RABBITMQ_ENABLED=true
# Required: in-container file storage root mounted from the files_data volume.
FILES_ROOT=/data
# Required secret: JWT signing key; replace with a long random value before first production use.
JWT_SECRET=change-me-jwt-secret
# Required: comma-separated browser origins allowed to call the API; do not use `*` in production.
CORS_ORIGINS=http://localhost:8080

# Translation
# Required: LibreTranslate HTTP URL used for language detection and translation.
LIBRETRANSLATE_URL=http://libretranslate:5000
# Optional: comma-separated list of language codes available for translation source/target.
# These codes are served by the bundled LibreTranslate image. Unsupported languages are
# indexed and searchable as original text but not offered for translation.
# Chinese support in this RC means Chinese Simplified (zh) only.
SUPPORTED_TRANSLATION_SOURCE_LANGUAGES=en,he,zh,ko,th,ar,fr,ru,es
SUPPORTED_TRANSLATION_TARGET_LANGUAGES=en,he,zh,ko,th,ar,fr,ru,es

# Local LLM
# Required when intelligence features are enabled: Ollama HTTP URL.
OLLAMA_URL=http://ollama:11434
# Required when intelligence features are enabled: Ollama model name to use for summaries, tags, and Q&A.
# Recommended models by RAM:
#   phi3:mini                   (~2.3 GiB, smallest)
#   llama3.2:3b-instruct-q8_0   (~3.2 GiB)
#   mistral:7b-instruct-v0.3    (~4.1 GiB, best quality)
OLLAMA_MODEL=phi3:mini
# Ollama safety defaults — conservative values for single-host deployment.
# Reduce CONTEXT_LENGTH (e.g. 1024) on hosts with less than 16 GB RAM.
# Do not increase NUM_PARALLEL or MAX_LOADED_MODELS without monitoring.
OLLAMA_CONTEXT_LENGTH=2048
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_QUEUE=8
OLLAMA_KEEP_ALIVE=1m

# Auth
# Required: authentication backend; use `local`, `ldap`, or `both`.
AUTH_PROVIDER=local
# Required only when AUTH_PROVIDER is `ldap` or `both`: LDAP server URL.
LDAP_URL=ldap://domain-controller:389
# Required only when AUTH_PROVIDER is `ldap` or `both`: LDAP search base DN.
LDAP_BASE_DN=DC=company,DC=local
# Required only when AUTH_PROVIDER is `ldap` or `both`: LDAP bind user DN.
LDAP_BIND_USER=cn=svc-search,DC=company,DC=local
# Required secret only when AUTH_PROVIDER is `ldap` or `both`: LDAP bind user password.
LDAP_BIND_PASSWORD=change-me-ldap-bind-password

# Feature flags and runtime defaults. Database-backed system_config values can override these at runtime.
# Optional feature flag: enable document comment APIs and UI behavior.
FEATURE_DOCUMENT_COMMENTS=true
# Optional feature flag: enable retrieval-augmented Q&A features.
FEATURE_RAG_QA=true
# Optional: max chunks returned by RAG retrieval.
RAG_MAX_CHUNKS=5
# Optional: score threshold for RAG chunk filtering (0.0 - 1.0).
RAG_SCORE_THRESHOLD=0.0
# Optional: max tokens for RAG context.
RAG_MAX_TOKENS_CONTEXT=2000
# Optional feature flag: enable document summarization.
FEATURE_SUMMARIZATION=true
# Optional feature flag: enable entity extraction.
FEATURE_ENTITY_EXTRACTION=true
# Optional feature flag: enable document annotations.
FEATURE_ANNOTATIONS=true
# Optional feature flag: enable subscription and notification discovery features.
FEATURE_SUBSCRIPTIONS=true
# Optional feature flag: enable expertise map features.
FEATURE_EXPERTISE_MAP=true
# Optional feature flag: enable related-document discovery.
FEATURE_RELATED_DOCS=true
# Optional feature flag: enable automatic tagging.
FEATURE_AUTO_TAGGING=true
# Optional local-development default: document view count that triggers automatic translation enrichment.
AUTO_ENRICH_THRESHOLD=5
# Optional local-development default: ingestion mode, one of `hybrid`, `watch`, or `poll`.
INGEST_MODE=hybrid

# Embedding provider
# Optional: embedding provider for vector search. Leave empty to use smart defaults:
#   - production (APP_ENV=prod) defaults to `ollama`
#   - development/test defaults to `deterministic-test`
# Explicit values: `ollama`, `deterministic-test`.
EMBEDDING_PROVIDER=
# Required when provider is `ollama` (or empty in production): Ollama embedding model name.
EMBEDDING_MODEL=nomic-embed-text
# Optional: override the Ollama URL used for embeddings. Defaults to OLLAMA_URL when empty.
EMBEDDING_URL=
# Optional: embedding vector dimension. Must match the model's output dimension.
# Common values: nomic-embed-text=768, mxbai-embed-large=1024.
EMBEDDING_DIMENSION=768
# Optional: maximum estimated tokens per text sent to the embedding model.
# Prevents context-length overflow for long chunks. Default 1024.
EMBEDDING_MAX_TOKENS=1024
# DANGER: explicitly allow deterministic-test encoder in production. Only set this
# if you understand the risks. Not recommended for production deployments.
EMBEDDING_PROVIDER_UNSAFE_ALLOW_TEST_IN_PROD=false

# Resource safety guards. These set Docker container resource limits (cpus, memory, PIDs)
# so that Tomorrowland runs safely on a single Docker host without exhausting CPU or RAM.
# Adjust for your host capacity before scaling replicas.
# API container — handles HTTP requests.
# API_CPUS=1.00
# API_MEM_LIMIT=1g
# API_MEM_RESERVATION=256m
# API_PIDS_LIMIT=512

# Pipeline worker — processes document extraction, translation, and indexing.
# PIPELINE_WORKER_CPUS=1.00
# PIPELINE_WORKER_MEM_LIMIT=1536m
# PIPELINE_WORKER_MEM_RESERVATION=256m
# PIPELINE_WORKER_PIDS_LIMIT=512

# Vector worker — encodes chunks and indexes Qdrant vectors.
# VECTOR_WORKER_CPUS=1.00
# VECTOR_WORKER_MEM_LIMIT=1536m
# VECTOR_WORKER_MEM_RESERVATION=256m
# VECTOR_WORKER_PIDS_LIMIT=512

# Embed worker — chunks documents and calls the embedding model (nomic-embed-text via Ollama).
# Needs more memory than a plain worker because it holds chunk batches in memory.
# start_period in docker-compose is 90s to cover Ollama model warm-up on first boot.
# EMBED_WORKER_CPUS=1.00
# EMBED_WORKER_MEM_LIMIT=512m
# EMBED_WORKER_MEM_RESERVATION=128m
# EMBED_WORKER_PIDS_LIMIT=256

# Intelligence worker — runs LLM tasks (summarisation, tagging, entity extraction) via Ollama.
# The Python process is lightweight; heavy compute is in Ollama, not this container.
# INTELLIGENCE_WORKER_CPUS=1.00
# INTELLIGENCE_WORKER_MEM_LIMIT=512m
# INTELLIGENCE_WORKER_MEM_RESERVATION=128m
# INTELLIGENCE_WORKER_PIDS_LIMIT=256

# ollama-llm — serves the generative LLM (mistral by default). Highest memory consumer.
# OLLAMA_CPUS=2.00
# OLLAMA_MEM_LIMIT=4g
# OLLAMA_MEM_RESERVATION=1g
# OLLAMA_PIDS_LIMIT=1024
# LLM-specific context and safety defaults.
# OLLAMA_CONTEXT_LENGTH=2048
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_QUEUE=8
# OLLAMA_KEEP_ALIVE=1m

# ollama-embed — serves only the embedding model (nomic-embed-text by default).
# Lighter than ollama-llm; 2 GB is usually sufficient.
# OLLAMA_EMBED_CPUS=1.00
# OLLAMA_EMBED_MEM_LIMIT=2g
# OLLAMA_EMBED_MEM_RESERVATION=512m
# OLLAMA_EMBED_PIDS_LIMIT=512
# Host port for the embed Ollama instance (LLM uses OLLAMA_PORT=11434).
# OLLAMA_EMBED_PORT=11435

# LibreTranslate — language detection and translation service.
# LIBRETRANSLATE_CPUS=1.00
# LIBRETRANSLATE_MEM_LIMIT=2g
# LIBRETRANSLATE_MEM_RESERVATION=512m
# LIBRETRANSLATE_PIDS_LIMIT=512

# Elasticsearch — full-text search. Java heap is set via ES_JAVA_OPTS.
# ELASTICSEARCH_CPUS=1.50
# ELASTICSEARCH_MEM_LIMIT=2g
# ELASTICSEARCH_MEM_RESERVATION=1g
# ELASTICSEARCH_PIDS_LIMIT=512

# Qdrant — vector search.
# QDRANT_CPUS=1.00
# QDRANT_MEM_LIMIT=1536m
# QDRANT_MEM_RESERVATION=512m
# QDRANT_PIDS_LIMIT=512

# Meilisearch — optional hybrid search backend.
# MEILISEARCH_CPUS=1.00
# MEILISEARCH_MEM_LIMIT=1g
# MEILISEARCH_MEM_RESERVATION=256m
# MEILISEARCH_PIDS_LIMIT=512

# PostgreSQL — metadata database.
# POSTGRES_CPUS=1.00
# POSTGRES_MEM_LIMIT=1536m
# POSTGRES_MEM_RESERVATION=512m
# POSTGRES_PIDS_LIMIT=512

# Worker backpressure controls. Each worker processes one job per loop iteration
# by default; scaling containers increases concurrency. These values document the
# conservative baseline — do not increase unless the host has headroom.
# PIPELINE_WORKER_CONCURRENCY=1
# VECTOR_WORKER_CONCURRENCY=1
# MAX_CONCURRENT_EMBEDDING_JOBS=1
# MAX_CONCURRENT_TRANSLATION_JOBS=1
# MAX_CONCURRENT_INDEXING_JOBS=1
# MAX_CONCURRENT_OCR_JOBS=1

# Published local ports. Change these only when host ports conflict.
# Optional local port: API HTTP endpoint published from the api container.
API_PORT=8000
# Optional local port: frontend Nginx endpoint published from the frontend container.
FRONTEND_PORT=8080
# Optional local port: PostgreSQL endpoint published for local maintenance tools.
POSTGRES_PORT=5432
# Optional local port: Kafka/Redpanda endpoint published for local maintenance tools.
KAFKA_PORT=9092
# Optional local port: Elasticsearch endpoint published for local maintenance tools.
ELASTICSEARCH_PORT=9200
# Optional local port: Qdrant endpoint published for local maintenance tools.
QDRANT_PORT=6333
# Optional local port: LibreTranslate endpoint published for local maintenance tools.
LIBRETRANSLATE_PORT=5000
# Optional local port: Ollama endpoint published for local maintenance tools.
OLLAMA_PORT=11434

# Persistent Docker volume names.
# These control the actual Docker volume names while keeping internal Compose
# service mount references stable. Defaults use the tomorrowland_ prefix.
# Changing a value after data exists makes that data appear missing until the
# old volume name is restored or data is migrated.
# TOMORROWLAND_FILES_VOLUME=tomorrowland_files_data
# TOMORROWLAND_POSTGRES_VOLUME=tomorrowland_postgres_data
# TOMORROWLAND_KAFKA_VOLUME=tomorrowland_kafka_data
# TOMORROWLAND_ELASTICSEARCH_VOLUME=tomorrowland_elasticsearch_data
# TOMORROWLAND_QDRANT_VOLUME=tomorrowland_qdrant_data
# TOMORROWLAND_LIBRETRANSLATE_VOLUME=tomorrowland_libretranslate_data
# TOMORROWLAND_OLLAMA_VOLUME=tomorrowland_ollama_data
# TOMORROWLAND_PROMETHEUS_VOLUME=tomorrowland_prometheus_data
# TOMORROWLAND_GRAFANA_VOLUME=tomorrowland_grafana_data
