# Tomorrowland air-gapped Compose environment template.
# Copy to `.env`, replace every `change-me-*` placeholder, and keep real secrets
# outside source control and outside release artifacts.

APP_ENV=prod
APP_VERSION=airgap
BUILD_COMMIT=unknown

# First-party image tags loaded from the offline Docker image bundle by
# scripts/load-airgap-images.sh (split parts by default).
TOMORROWLAND_BACKEND_IMAGE=tomorrowland/backend:airgap
TOMORROWLAND_FRONTEND_IMAGE=tomorrowland/frontend:airgap
# LibreTranslate image with pre-installed language packs bundled for air-gapped operation.
TOMORROWLAND_LIBRETRANSLATE_IMAGE=tomorrowland/libretranslate:airgap

# Core services
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_URL=postgresql+psycopg://postgres:change-me-postgres-password@postgres:5432/app
KAFKA_BROKER=kafka:9092
QDRANT_URL=http://qdrant:6333
FILES_ROOT=/data
JWT_SECRET=change-me-jwt-secret
CORS_ORIGINS=http://localhost:8080

# Search backend (Meilisearch) — required for keyword/BM25 search. The offline
# image bundle ships getmeili/meilisearch:v1.9.
MEILISEARCH_URL=http://meilisearch:7700
# Master key authenticates the api and workers to Meilisearch. Replace the
# placeholder; in production mode the key must be at least 16 bytes.
MEILISEARCH_MASTER_KEY=change-me-meilisearch-master-key
# Meilisearch runs in production mode in air-gapped deployments.
MEILISEARCH_ENV=production
FEATURE_MEILISEARCH_SEARCH=true
FEATURE_MEILISEARCH_SHADOW_INDEX=true

# Pipeline job bus (RabbitMQ) — required. The api publishes pipeline stage
# messages; the parse/translate/embed/index/intelligence/alert/enrich workers
# consume them. Keep RABBITMQ_PASS and the password in RABBITMQ_URL in sync.
RABBITMQ_ENABLED=true
RABBITMQ_USER=tomorrowland
RABBITMQ_PASS=change-me-rabbitmq-password
RABBITMQ_URL=amqp://tomorrowland:change-me-rabbitmq-password@rabbitmq:5672/

# Translation service included in the offline image bundle.
LIBRETRANSLATE_URL=http://libretranslate:5000
# Supported translation language codes bundled in the air-gapped LibreTranslate image.
# Unsupported languages are indexed and searchable as original text but not translated.
# Chinese support means Chinese Simplified (zh) only.
SUPPORTED_TRANSLATION_SOURCE_LANGUAGES=en,he,zh,ko,th,ar,fr,ru,es
SUPPORTED_TRANSLATION_TARGET_LANGUAGES=en,he,zh,ko,th,ar,fr,ru,es

# Local AI (Ollama) — OPTIONAL. The platform starts and functions without it.
# Ollama model bundles are separate optional release assets. The Docker image
# for Ollama is bundled, but no models are pre-loaded. Transfer and load a model
# bundle only when offline Q&A/RAG/local intelligence is required. Missing model
# bundle produces degraded AI features but does not prevent platform startup.
OLLAMA_URL=http://ollama:11434
# Default model; not pre-loaded. Override after loading a matching model bundle.
OLLAMA_MODEL=qwen3:4b
# Optional: smaller/faster model for cheap repeated tasks. Falls back to OLLAMA_MODEL when empty.
OLLAMA_UTILITY_MODEL=
# Optional: dedicated model for cross-encoder reranking. Falls back to OLLAMA_UTILITY_MODEL
# (then OLLAMA_MODEL) when empty.
OLLAMA_RERANKER_MODEL=

# --- External / OpenAI-compatible LLM (OPTIONAL) ---------------------------
# Instead of loading an Ollama model bundle, point Tomorrowland at an external
# local LLM that speaks the OpenAI API — e.g. a LiteLLM proxy, vLLM, LM Studio,
# or llama.cpp server running on the host or elsewhere on the air-gapped network.
# When LLM_PROVIDER is set it overrides the OLLAMA_* settings above for the api
# AND every pipeline worker (chat, RAG, summaries, tagging, entity extraction).
#
# Deployment behaviour (scripts/tomorrowland-airgap.sh up):
#   LLM_PROVIDER empty  -> bundled Ollama is started (the "local-llm" Compose
#                          profile is activated automatically). Requires the
#                          ollama/ollama image in the bundle.
#   LLM_PROVIDER set     -> bundled Ollama is NOT started; the api and workers
#                          use the external endpoint below. Deployable from a
#                          no-Ollama bundle (built with INCLUDE_OLLAMA_IMAGE=0).
#
# Supported values: litellm | openai-compatible | openai | llama-cpp | ollama
# LiteLLM example (proxy must be reachable from inside the containers; on Linux
# use the host's LAN IP, add the proxy as a Compose service, or set extra_hosts —
# host.docker.internal is only resolvable on Docker Desktop):
#   LLM_PROVIDER=litellm
#   LLM_BASE_URL=http://<litellm-host>:4000
#   LLM_MODEL=qwen2.5:7b-instruct        # a model your proxy actually serves
#   LLM_API_KEY=sk-...                    # only if the proxy enforces a key
LLM_PROVIDER=
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# Auth: use local, ldap, or both. LDAP placeholders are ignored when AUTH_PROVIDER=local.
AUTH_PROVIDER=local
LDAP_URL=ldap://domain-controller:389
LDAP_BASE_DN=DC=company,DC=local
LDAP_BIND_USER=cn=svc-search,DC=company,DC=local
LDAP_BIND_PASSWORD=change-me-ldap-bind-password

# Folder connector host mount. Create this host path before starting Compose and
# use the container path when adding the folder source in Admin Sources.
TOMORROWLAND_FOLDER_SOURCE_HOST_PATH=./operator-data/folder-source
TOMORROWLAND_FOLDER_SOURCE_CONTAINER_PATH=/sources/folder

# Feature flags and runtime defaults.
FEATURE_DOCUMENT_COMMENTS=true
FEATURE_RAG_QA=true
FEATURE_SUMMARIZATION=true
FEATURE_ENTITY_EXTRACTION=true
FEATURE_ANNOTATIONS=true
FEATURE_SUBSCRIPTIONS=true
FEATURE_EXPERTISE_MAP=true
FEATURE_RELATED_DOCS=true
FEATURE_AUTO_TAGGING=true
AUTO_ENRICH_THRESHOLD=5

# Embedding provider — OPTIONAL. Without it, semantic search degrades to
# lexical-only (BM25); the platform still starts and searches.
# In air-gapped production deployments the default is `ollama`. Set to
# `openai-compatible` to use an external OpenAI-style embedding endpoint (e.g. a
# LiteLLM proxy via EMBEDDING_URL below). Only override to `deterministic-test`
# for offline evaluation without a real embedding model.
EMBEDDING_PROVIDER=
# Required when provider is `ollama`: Ollama embedding model name.
# The embedding model is part of the optional AI model bundle.
EMBEDDING_MODEL=qwen3-embedding:8b
# Ollama URL used for embeddings (air-gapped compose uses a single ollama service
# that serves both generation and embedding models).
EMBEDDING_URL=http://ollama:11434
# Bearer key for an OpenAI-compatible embedding endpoint (LiteLLM, etc.).
# Leave empty for the bundled Ollama, which needs no auth.
EMBEDDING_API_KEY=
# Optional: embedding vector dimension. Must match the model's output dimension.
# nomic-embed-text = 768; mxbai-embed-large = 1024; qwen3-embedding:8b = 4096.
EMBEDDING_DIMENSION=4096
# Maximum seconds the search endpoint waits for the embedding service before
# falling back to lexical-only results. Keep below nginx read timeout (~110 s).
SEARCH_EMBEDDING_TIMEOUT=5

# Published host ports. In the air-gapped compose file, the direct API port and
# infrastructure ports are bound to 127.0.0.1; expose them outside the host only
# with deliberate firewall and reverse-proxy controls.
API_PORT=8000
FRONTEND_PORT=8080
POSTGRES_PORT=5432
KAFKA_PORT=9092
QDRANT_PORT=6333
MEILISEARCH_PORT=7700
LIBRETRANSLATE_PORT=5000
OLLAMA_PORT=11434
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Persistent Docker volume names.
# These control the actual Docker volume names while keeping internal Compose
# service mount references stable. Defaults use the tomorrowland_ prefix.
# Changing a value after data exists makes that data appear missing until the
# old volume name is restored or data is migrated.
# TOMORROWLAND_FILES_VOLUME=tomorrowland_files_data
# TOMORROWLAND_POSTGRES_VOLUME=tomorrowland_postgres_data
# TOMORROWLAND_KAFKA_VOLUME=tomorrowland_kafka_data
# TOMORROWLAND_MEILISEARCH_VOLUME=tomorrowland_meilisearch_data
# TOMORROWLAND_QDRANT_VOLUME=tomorrowland_qdrant_data
# TOMORROWLAND_MEILISEARCH_VOLUME=tomorrowland_meilisearch_data
# TOMORROWLAND_LIBRETRANSLATE_VOLUME=tomorrowland_libretranslate_data
# TOMORROWLAND_OLLAMA_VOLUME=tomorrowland_ollama_data
# TOMORROWLAND_RABBITMQ_VOLUME=tomorrowland_rabbitmq_data
