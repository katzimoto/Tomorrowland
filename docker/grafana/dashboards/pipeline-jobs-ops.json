  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Dead-letter jobs",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
          "rawSql": "SELECT COUNT(*) AS count FROM pipeline_jobs WHERE status = 'dead_letter'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^count$/" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
