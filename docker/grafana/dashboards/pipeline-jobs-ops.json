    {
      "id": 5,
      "type": "table",
      "title": "Dead-letter jobs",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
          "rawSql": "SELECT id, document_id, job_type, attempts, max_attempts, last_error, stage, updated_at FROM pipeline_jobs WHERE status = 'dead_letter' ORDER BY updated_at DESC LIMIT 100",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "last_error" },
            "properties": [{ "id": "custom.width", "value": 220 }]
          },
          {
            "matcher": { "id": "byName", "options": "id" },
            "properties": [{ "id": "custom.width", "value": 300 }]
          },
          {
            "matcher": { "id": "byName", "options": "document_id" },
            "properties": [{ "id": "custom.width", "value": 300 }]
          },
          {
            "matcher": { "id": "byName", "options": "updated_at" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "unit", "value": "dateTimeAsIso" }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false },
        "sortBy": [{ "displayName": "updated_at", "desc": true }]
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Active jobs (pending / running / retry)",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
          "rawSql": "SELECT id, document_id, job_type, status, attempts, max_attempts, stage, locked_by, run_after, updated_at FROM pipeline_jobs WHERE status IN ('pending', 'running', 'retry') ORDER BY priority DESC, created_at ASC LIMIT 100",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "id" },
            "properties": [{ "id": "custom.width", "value": 300 }]
          },
          {
            "matcher": { "id": "byName", "options": "document_id" },
            "properties": [{ "id": "custom.width", "value": 300 }]
          },
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.width", "value": 90 },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "pending":  { "color": "blue",   "index": 0 } } },
                  { "type": "value", "options": { "running":  { "color": "green",  "index": 1 } } },
                  { "type": "value", "options": { "retry":    { "color": "orange", "index": 2 } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "run_after" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "unit", "value": "dateTimeAsIso" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "updated_at" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "unit", "value": "dateTimeAsIso" }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Job counts by type and status (last 24 h)",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
          "rawSql": "SELECT job_type, status, COUNT(*) AS count FROM pipeline_jobs WHERE updated_at >= NOW() - INTERVAL '24 hours' GROUP BY job_type, status ORDER BY job_type, status",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "footer": { "show": false }
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recently failed jobs (last 24 h)",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "tomorrowland-postgres" },
          "rawSql": "SELECT id, document_id, job_type, last_error, attempts, updated_at FROM pipeline_jobs WHERE status IN ('dead_letter', 'retry') AND updated_at >= NOW() - INTERVAL '24 hours' ORDER BY updated_at DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "updated_at" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "unit", "value": "dateTimeAsIso" }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false }
      }
    }
  ],
