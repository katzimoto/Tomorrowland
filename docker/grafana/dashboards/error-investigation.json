  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total log lines",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
          "expr": "count_over_time({service=~\".+\"} |= \"$correlation_id\" [$__range])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error lines",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
          "expr": "count_over_time({service=~\".+\"} |= \"$correlation_id\" |~ \"(?i)(\\\"level\\\":\\\"ERROR\\\"|\\bERROR\\b|\\bexception\\b|\\btraceback\\b)\" [$__range])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Warning lines",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
          "expr": "count_over_time({service=~\".+\"} |= \"$correlation_id\" |~ \"(?i)(\\\"level\\\":\\\"WARNING\\\"|\\bWARNING\\b|\\bWARN\\b)\" [$__range])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
