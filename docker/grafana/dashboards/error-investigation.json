      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
          "expr": "sum by (service) (count_over_time({service=~\".+\"} |= \"$correlation_id\" [1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "stacking": { "group": "A", "mode": "normal" } } },
        "overrides": []
