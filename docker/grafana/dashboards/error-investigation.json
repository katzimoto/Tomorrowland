      "title": "Errors and warnings only",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
          "expr": "{service=~\".+\", level=~\"ERROR|WARNING|error|warning\"} |= \"$correlation_id\"",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
          "expr": "{service=~\".+\", level=\"\"} |= \"$correlation_id\" |~ \"(?i)(\\bERROR\\b|\\bWARNING\\b|\\bexception\\b|\\btraceback\\b)\"",
          "refId": "B",
          "hide": false
        }
