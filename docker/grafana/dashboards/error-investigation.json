      "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "tomorrowland-loki" },
          "expr": "sum by (service) (count_over_time({service=~\".+\"} |= \"$correlation_id\" [$__range]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"] } }
