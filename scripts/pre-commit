#!/usr/bin/env bash
# check-pr-cleanliness.sh — Block commits that would break CI
#
# Usage: bash scripts/pre-commit
# Install as hook: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "=== Pre-commit CI gate ==="

FAILED=0

# ── 1. Block agent artifacts ──────────────────────────────────────────────────
ARTIFACTS=(".opencode_auth.json" "token_opencode.txt")
for artifact in "${ARTIFACTS[@]}"; do
    if git diff --cached --name-only | grep -qxF "$artifact"; then
        echo "FAIL: Agent artifact '$artifact' is staged for commit."
        echo "  Add it to .git/info/exclude instead."
        FAILED=1
    fi
done

# Block root-level 'main' file (no extension)
if git diff --cached --name-only | grep -qxE "main"; then
    echo "FAIL: Root-level file 'main' (no extension) is staged — likely an agent artifact."
    FAILED=1
fi

# ── 2. Ruff lint (only staged Python files) ───────────────────────────────────
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)
if [ -n "$STAGED_PY" ]; then
    echo "Running ruff check on staged Python files..."
    RUFF_OUTPUT=$(echo "$STAGED_PY" | xargs uv run ruff check 2>&1)
    RUFF_EXIT=$?
    if [ $RUFF_EXIT -ne 0 ]; then
        echo "$RUFF_OUTPUT"
        echo "FAIL: ruff check failed. Run: uv run ruff check --fix"
        FAILED=1
    fi
fi

# ── 3. Ruff format check (only staged Python files) ───────────────────────────
if [ -n "$STAGED_PY" ]; then
    echo "Running ruff format check on staged Python files..."
    FMT_OUTPUT=$(echo "$STAGED_PY" | xargs uv run ruff format --check 2>&1)
    FMT_EXIT=$?
    if [ $FMT_EXIT -ne 0 ]; then
        echo "$FMT_OUTPUT"
        echo "FAIL: ruff format check failed. Run: uv run ruff format"
        FAILED=1
    fi
fi

# ── 4. Block known dangerous patterns in Python files only ────────────────────
STAGED_PY_DIFF=$(git diff --cached -U0 -- '*.py' 2>/dev/null || true)
if [ -n "$STAGED_PY_DIFF" ]; then
    DANGEROUS=("shell=True" "pickle.loads" "pickle.load" "exec(" "eval(" "os.system(")
    for pattern in "${DANGEROUS[@]}"; do
        if echo "$STAGED_PY_DIFF" | grep -q "$pattern"; then
            echo "FAIL: Dangerous pattern detected in staged Python diff: $pattern"
            echo "  Review the change and remove if not intentional."
            FAILED=1
        fi
    done
fi

# ── Result ────────────────────────────────────────────────────────────────────
echo
if [ "$FAILED" -eq 0 ]; then
    echo "PASS: All pre-commit checks passed."
    exit 0
else
    echo "FAIL: Pre-commit checks failed. Fix the issues above before committing."
    echo "  To bypass (not recommended): git commit --no-verify"
    exit 1
fi
